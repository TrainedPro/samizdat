namespace com.fyp.resilientp2p.audio {
    class AudioPlayer {
        -inputStream : InputStream
        -log : (String, LogLevel) -> Unit, private val peerRttMs: Long
    }
    class Buffer {
        +validSize(size: Int) Boolean
        +getMinBufferSize(sampleRate: Int) Int
    }
    class AudioBuffer {
        <<abstract>>
        -log : (String, LogLevel) -> Unit
        -TAG : String
        +size : Int
        +sampleRate : Int
        +data : ByteArray
        +calculatedSize : Any
        #validSize(size: Int) Boolean
        #getMinBufferSize(sampleRate: Int) Int
    }
    class AudioCodecManager {
        -TAG : String
        +SAMPLE_RATE : Int
        +BIT_RATE : Any
        +CHANNELS : Int
        +FRAME_DURATION_MS : Int
        +SAMPLES_PER_FRAME : SAMPLE_RATE
        +BYTES_PER_FRAME : SAMPLES_PER_FRAME
        +logFn : ((String, LogLevel) -> Unit)?
        -log(msg: String, level: LogLevel = LogLevel.DEBUG) Unit
        +createEncoder() AACEncoder?
        +createDecoder() AACDecoder?
    }
    class AACEncoder {
        -codec : MediaCodec
        -bufferInfo : MediaCodec.BufferInfo
        -isReleased : Boolean
        +format : MediaFormat.createAudioFormat
        +output : ByteArrayOutputStream
        +inputIndex : Any
        +inputBuffer : Any
        +outputIndex : Any
        +outputBuffer : Any
        +chunk : ByteArray
        +encode(pcmData: ByteArray) ByteArray
        +release() Unit
    }
    class AACDecoder {
        -codec : MediaCodec
        -bufferInfo : MediaCodec.BufferInfo
        -isReleased : Boolean
        +format : MediaFormat.createAudioFormat
        +csd : ByteBuffer.wrap
        +output : ByteArrayOutputStream
        +inputIndex : Any
        +inputBuffer : Any
        +outputIndex : Any
        +outputBuffer : Any
        +chunk : ByteArray
        +decode(aacData: ByteArray) ByteArray
        +release() Unit
    }
    class MeshAudioManager {
        -context : Context
        -localUsername : String
        -log : (String, LogLevel) -> Unit
    }
    class AudioRecorder {
        -context : android.content.Context
        -log : (String, LogLevel) -> Unit
    }
}
namespace com.fyp.resilientp2p.data {
    class Converters {
        +fromLogLevel(value: LogLevel) String
        +toLogLevel(value: String) LogLevel
        +fromLogType(value: LogType) String
        +toLogType(value: String) LogType
        +fromMessageType(value: MessageType) String
        +toMessageType(value: String) MessageType
        +fromTelemetryEventType(value: TelemetryEventType) String
        +toTelemetryEventType(value: String) TelemetryEventType
    }
    class EncounterLog {
        <<Entity>>
        <<data>>
        +id : Long
        +localPeer : String
        +remotePeer : String
        +startTime : Long
        +endTime : Long
        +packetsExchanged : Int
        +bytesExchanged : Long
        +rssi : Int
    }
    class AppDatabase {
        <<Database>>
        <<abstract>>
        -INSTANCE : AppDatabase?
        +instance : Any
        +logDao() LogDao
        +packetDao() PacketDao
        +chatDao() ChatDao
        +telemetryDao() TelemetryDao
        +chatGroupDao() ChatGroupDao
        +groupMessageDao() GroupMessageDao
        +sharedFileDao() SharedFileDao
        +encounterDao() EncounterDao
        +downloadedChunkDao() DownloadedChunkDao
        +getDatabase(context: Context) AppDatabase
    }
    class DownloadedChunk {
        <<Entity>>
        <<data>>
        +sha256 : String
        +chunkIndex : Int
    }
    class DownloadedChunkDao {
        <<Dao>>
        <<interface>>
        +getReceivedChunks(sha256: String) List<Int>
        +markChunkReceived(chunk: DownloadedChunk) Unit
        +clearChunks(sha256: String) Unit
        +deleteAll() Unit
    }
    class ChatGroup {
