    class MessageCache {
        -capacity : Int
        -cache : ConcurrentHashMap<String, Long>
        -cleanupLock : AtomicBoolean
        -ttl : Any
        +now : System.currentTimeMillis
        +previous : Any
        +now : System.currentTimeMillis
        +targetSize : Any
        +minTs : Long.MAX_VALUE
        +maxTs : Long.MIN_VALUE
        +threshold : Any
        +iter : Any
        +tryMarkSeen(packetId: String) Boolean
        -evictOldEntries() Unit
        +clear() Unit
    }
    class PacketType {
        <<enumeration>>
    }
    class Hop {
        <<data>>
        +peerId : String
        +rssi : Int
    }
    class Packet {
        <<data>>
        +id : String
        +type : PacketType
        +timestamp : Long
        +sourceId : String
        +destId : String
        +payload : ByteArray
        +ttl : Int
